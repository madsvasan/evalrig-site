---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Independent AI benchmarks. Models tested head-to-head with deterministic rules and ensemble LLM judges.',
  ogImage = 'https://evalrig.ai/og-image.png',
  jsonLd,
} = Astro.props;

const siteTitle = title ? `${title} — EvalRig` : 'EvalRig — Independent AI Benchmarks';
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="description" content={description} />
    <title>{siteTitle}</title>

    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={`https://evalrig.ai${currentPath}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="logo-link">
          <img src="/logo.svg" alt="EvalRig" class="logo-img" />
        </a>
        <nav class="nav-links">
          <a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a>
          <a href="/benchmarks/" class:list={[{ active: currentPath.startsWith('/benchmarks') }]}>Benchmarks</a>
          <a href="/about/" class:list={[{ active: currentPath === '/about/' }]}>About</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <nav class="footer-nav">
          <a href="/">Home</a>
          <a href="/benchmarks/">Benchmarks</a>
          <a href="/about/">About</a>
          <a href="https://turanu.ai/#/portal/signup/free" target="_blank" rel="noopener">Subscribe</a>
        </nav>
        <p>
          &copy; 2026 <a href="https://turanu.ai" target="_blank" rel="noopener">Turanu AI</a>
        </p>
      </div>
    </footer>
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "12b37d3a94124054aa49da53937def16"}'></script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 11, 0.85);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo-link {
    line-height: 0;
  }

  .logo-img {
    height: 44px;
    width: auto;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .nav-links a {
    color: var(--text-muted);
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-links a.active {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .site-footer a {
    color: var(--text-muted);
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
  }

  .footer-nav a {
    color: var(--text-dim);
  }

  .footer-nav a:hover {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .logo-img {
      height: 36px;
    }

    .nav-links {
      gap: 1.25rem;
      font-size: 0.8rem;
    }
  }
</style>
