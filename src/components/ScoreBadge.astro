---
interface Props {
  score: number;
  rank?: number;
}

const { score, rank } = Astro.props;
const cls = rank === 1 ? 'badge rank-1' : rank === 2 ? 'badge rank-2' : 'badge';
---

<span class={cls}>{score.toFixed(2)}</span>

<style>
  .badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.8rem;
    background: rgba(228, 228, 231, 0.06);
    color: var(--text-muted);
  }

  .rank-1 {
    background: var(--accent-subtle);
    color: var(--accent);
  }

  .rank-2 {
    background: rgba(228, 228, 231, 0.08);
    color: var(--text);
  }
</style>
