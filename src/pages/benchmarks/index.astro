---
import Base from '../../layouts/Base.astro';
import BenchmarkCard from '../../components/BenchmarkCard.astro';
---

<Base title="Benchmarks">
  <div class="page-header">
    <h1>Benchmarks</h1>
    <p class="page-desc">
      AI models tested head-to-head on real workflow tasks. Deterministic rules,
      ensemble judges, no vendor bias.
    </p>
  </div>

  <div class="benchmarks-list">
    <BenchmarkCard
      slug="frontier-showdown"
      title="Frontier Model Showdown"
      date="2026-03-08"
      department="Frontier Model Evals"
      models={3}
      skills={4}
      runs={12}
      bestValue="Gemini 3.1 Pro"
      bestValueScore="0.768 avg, $0.31 cost"
      bestOverall="Claude Opus 4.6"
      bestOverallScore="0.825 avg"
      headline="Three frontier models tested on frontend design, MCP server builder, skill creator, and Excel generation. Claude scored highest. Gemini was cheapest."
    />
  </div>

  <div class="upcoming">
    <h2>Upcoming</h2>
    <div class="upcoming-list">
      <div class="upcoming-item next">
        <span class="upcoming-dept">Customer Success</span>
        <span class="upcoming-skills">Ticket triage, complaint response, knowledge base generation, churn analysis</span>
      </div>
      <div class="upcoming-item">
        <span class="upcoming-dept">Sales</span>
        <span class="upcoming-skills">Lead scoring, outreach drafting, pipeline analysis, competitor intel</span>
      </div>
      <div class="upcoming-item">
        <span class="upcoming-dept">Marketing</span>
        <span class="upcoming-skills">Campaign copy, audience segmentation, content calendar, performance analysis</span>
      </div>
      <div class="upcoming-item">
        <span class="upcoming-dept">HR</span>
        <span class="upcoming-skills">Job descriptions, resume screening, onboarding plans, policy Q&A</span>
      </div>
      <div class="upcoming-item">
        <span class="upcoming-dept">IT / DevOps</span>
        <span class="upcoming-skills">Incident triage, runbook generation, capacity planning, config review</span>
      </div>
      <div class="upcoming-item">
        <span class="upcoming-dept">Legal</span>
        <span class="upcoming-skills">Contract review, compliance checks, risk assessment, policy drafting</span>
      </div>
      <div class="upcoming-item">
        <span class="upcoming-dept">Finance</span>
        <span class="upcoming-skills">Variance analysis, forecast modeling, expense audit, report generation</span>
      </div>
    </div>
  </div>

  <div class="subscribe-cta">
    <p>Get notified when new benchmarks drop.</p>
    <a href="https://turanu.ai/#/portal/signup/free" class="btn-subscribe" target="_blank" rel="noopener">Subscribe &mdash; it's free</a>
  </div>
</Base>

<style>
  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 640px;
  }

  .benchmarks-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }

  .upcoming {
    margin-bottom: 3rem;
  }

  .upcoming h2 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .upcoming-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .upcoming-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    opacity: 0.6;
  }

  .upcoming-item.next {
    opacity: 0.9;
    border-color: var(--accent);
    border-left: 3px solid var(--accent);
  }

  .upcoming-dept {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text);
    min-width: 100px;
  }

  .upcoming-skills {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .subscribe-cta {
    text-align: center;
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
  }

  .subscribe-cta p {
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .btn-subscribe {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: var(--accent);
    color: white;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    transition: background 0.2s;
  }

  .btn-subscribe:hover {
    background: var(--accent-hover);
    color: white;
  }

  @media (max-width: 640px) {
    .upcoming-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>
